# YouTube — ListQik University (/listqik-university)
# Copy these lines into .env.local (all optional unless you want API mode).

# Public channel: https://www.youtube.com/@ListQuick
YOUTUBE_CHANNEL_URL="https://www.youtube.com/@ListQuick"
YOUTUBE_CHANNEL_HANDLE="ListQuick"
YOUTUBE_CHANNEL_ID="UCijYyspf6u9RSR2vg82A__A"

# How many videos to show (default 12, max 50)
# YOUTUBE_MAX_VIDEOS="12"

# Optional: YouTube Data API v3 key for richer metadata (Google Cloud Console).
# Without a key, the site uses YouTube's public RSS feed (no quota, auto-updates).
# YOUTUBE_API_KEY="AIza..."
