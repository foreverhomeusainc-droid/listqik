# Copy to .env.local (gitignored) and fill in values.

# MongoDB connection string (Atlas or self-hosted)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/listpath?retryWrites=true&w=majority

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-random-string
NEXTAUTH_URL=http://localhost:3000

# When checkout is paid, POST here with header x-webhook-secret: <same value>.
# Mirror the pricing wizard payload where possible: contact, plan, property, upgrades, plus
# externalOrderId (payment txn id) for idempotent retries. Response may include setupAccountUrl for new buyers.
ORDER_WEBHOOK_SECRET=replace-with-long-random-secret

# Transactional email (setup-account, listing finalize, upgrades, admin test)
# Gmail: use smtp.gmail.com, port 587, App Password as SMTP_PASS (not your login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=concierge@listqik.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=ListQik <concierge@listqik.com>
# Internal purchase alerts (plan, upgrade, full service). Comma-separated.
INTERNAL_NOTIFICATIONS_EMAIL=concierge@listqik.com
# Admin console access; fallback internal alert recipients if INTERNAL_NOTIFICATIONS_EMAIL is unset
ADMIN_EMAILS=concierge@listqik.com

# Stripe (checkout + webhooks). Run: npm run stripe:create-catalog
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# JSON maps printed by stripe:create-catalog (slug -> price_...)
STRIPE_PLAN_PRICE_IDS_JSON={"subsonic":"price_...","supersonic":"price_...","hypersonic":"price_..."}
STRIPE_UPGRADE_PRICE_IDS_JSON={"premium-photography-spotlight-listing":"price_..."}
# Full service tiers: market-expert ($199 onboarding), local-expert ($299 onboarding)
STRIPE_FULL_SERVICE_PRICE_IDS_JSON={"market-expert":"price_...","local-expert":"price_..."}
# Velocity Club pipeline bundles (5 / 10 / 25 listing credits). Run: npm run stripe:create-catalog
STRIPE_CREDIT_BUNDLE_PRICE_IDS_JSON={"pipeline-5":"price_...","pipeline-10":"price_...","pipeline-25":"price_..."}

# Vercel Cron auth for /api/cron/loyalty (Authorization: Bearer <secret>)
CRON_SECRET=replace-with-long-random-secret

# Calculator Center — anonymous runs per tool per day (default 3)
CALCULATOR_ANON_DAILY_LIMIT=3

# map your internal plan slug -> GHL product id (fallback source for looking up price IDs).
# Example values are from this workspace's created products.
GHL_PLAN_PRODUCT_IDS={"subsonic":"69f4cefde67f70f867e8fa1b","supersonic":"69f4cefec4c5d25d45c0adeb","hypersonic":"69f4ceffcb5c2488ec2f7b36"}

# Preferred for cart-style checkout injection (most GHL checkouts expect price IDs in `products`).
# plan slug -> price id
GHL_PLAN_PRICE_IDS={"subsonic":"<priceId>","supersonic":"<priceId>","hypersonic":"<priceId>"}
# upgrade slug -> price id
GHL_UPGRADE_PRICE_IDS={"premium-photography-spotlight-listing":"<priceId>"}

# GoHighLevel external tracking (Settings → External Tracking → Copy Script)
# Paste the data-tracking-id value only (tk_...)
NEXT_PUBLIC_GHL_TRACKING_ID=tk_your-tracking-id-here

# Google Ads (global site tag + purchase conversion). Tag ID is AW-18257270972.
# Purchase send_to must match Google Ads → Goals → Purchase → Tag setup.
NEXT_PUBLIC_GOOGLE_ADS_TAG_ID=AW-18257270972
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_SEND_TO=AW-18257270972/mGuxCOrF0cMcELyx34FE
# Optional: separate conversion for Subsonic intake started (start-now / county CTAs)
# NEXT_PUBLIC_GOOGLE_ADS_INTAKE_SEND_TO=AW-18257270972/xxxxxxxx

# GHL inline lead forms on county/DFW/start-now landers (EN + ES form ids in src/lib/ghl-inline-form.ts)
